# Market: set slug for btc/eth/sol/xrp and 5m/15m/1h (e.g. btc-updown-5m, eth-updown-15m, xrp-updown-1h)
POLYMARKET_SLUG_PREFIX=btc-updown-15m

# When winning token price (ask) is above this, buy (and below MAX_BUY_PRICE)
BUY_TRIGGER_PRICE=0.88
# Don't buy if price is above this (e.g. 0.95)
MAX_BUY_PRICE=0.95
# When bought token price drops to or below this, sell all (stop loss)
STOP_LOSS_PRICE=0.5
# Profit lock: sell when bought token price reaches this (e.g. 0.99)
PROFIT_LOCK_PRICE=0.99

BUY_AMOUNT_USD=5
# Extra % above price for buy so FAK order crosses spread (e.g. 0.03 = 3%)
BUY_PRICE_BUFFER=0.03
POLL_INTERVAL_MS=2000

ENABLE_WIN_BOT=true
ENABLE_AUTO_REDEEM=true
# Auto approve USDC every N minutes (4 or 5)
APPROVE_INTERVAL_MINUTES=5

CLOB_API_URL=https://clob.polymarket.com
CHAIN_ID=137
RPC_URL=wss://polygon-mainnet.infura.io/v3/e54d2d44af9c45a7b59e361917b0b370
RPC_TOKEN=


# Credentials: set PRIVATE_KEY to auto-create/update API key
PRIVATE_KEY=
PROXY_WALLET_ADDRESS=
